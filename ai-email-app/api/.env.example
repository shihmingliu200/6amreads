# Database (Supabase)
# Get from: Supabase → Project → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Anthropic Claude API
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# NewsAPI
# Get from: https://newsapi.org (free tier: 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# SendGrid
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_key_here
# Must be a verified sender in your SendGrid account
SENDGRID_FROM_EMAIL=you@yourdomain.com
SENDGRID_FROM_NAME=6amreads

# Server
PORT=3001

# JWT (required for auth)
JWT_SECRET=use_a_long_random_string

# Google Sign-In — must match web NEXT_PUBLIC_GOOGLE_CLIENT_ID (OAuth client ID)
GOOGLE_CLIENT_ID=

# Cron: fetch NewsAPI + send emails (default 5:30 AM daily)
CRON_SCHEDULE=30 5 * * *
CRON_TIMEZONE=America/Chicago

# Public URL of THIS API (used in email feedback links). e.g. https://api.6amreads.com
PUBLIC_API_URL=http://localhost:3001

# Optional: separate secret for email feedback HMAC (defaults to JWT_SECRET)
# EMAIL_FEEDBACK_SECRET=

# Anthropic model override (default: claude-3-5-sonnet-20241022)
# ANTHROPIC_MODEL=

# Admin backstage — header: X-Admin-Key: <value>
ADMIN_SECRET=change_this_to_something_secret
